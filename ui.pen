                                          "name": "introSummary",
                                          "fill": "#374151",
                                          "content": "A strong learning habit makes change feel navigable instead of disruptive.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 15,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "frame",
                                      "id": "SRF130",
                                      "name": "section2",
                                      "width": "fill_container",
                                      "layout": "vertical",
                                      "gap": 10,
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "SRF131",
                                          "name": "heading2",
                                          "fill": "#1A1A1A",
                                          "content": "# 2. Why Lifelong Learning Matters",
                                          "fontFamily": "Inter",
                                          "fontSize": 22,
                                          "fontWeight": "700"
                                        },
                                        {
                                          "type": "text",
                                          "id": "SRF132",
                                          "name": "section2Para",
                                          "fill": "#374151",
                                          "content": "People who keep learning adapt faster, spot better options, and stay open to new opportunities.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 15,
                                          "fontWeight": "normal"
                                        },
                                        {
                                          "type": "frame",
                                          "id": "SRF133",
                                          "name": "bulletList",
                                          "width": "fill_container",
                                          "layout": "vertical",

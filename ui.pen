                                            {
                                              "type": "text",
                                              "id": "SRF134",
                                              "name": "bullet1",
                                              "fill": "#374151",
                                              "content": "\u2022 It builds resilience when tools, roles, or expectations shift.",
                                              "lineHeight": 1.6,
                                              "fontFamily": "Inter",
                                              "fontSize": 15,
                                              "fontWeight": "normal"
                                            },
                                            {
                                              "type": "text",
                                              "id": "SRF135",
                                              "name": "bullet2",
                                              "fill": "#374151",
                                              "content": "\u2022 It improves problem-solving by exposing us to new ideas and patterns.",
                                              "lineHeight": 1.6,
                                              "fontFamily": "Inter",
                                              "fontSize": 15,
                                              "fontWeight": "normal"
                                            },
                                            {
                                              "type": "text",
                                              "id": "SRF136",
                                              "name": "bullet3",
                                              "fill": "#374151",
                                              "content": "\u2022 It keeps curiosity active, which often leads to better decisions.",
                                              "lineHeight": 1.6,
                                              "fontFamily": "Inter",
                                              "fontSize": 15,
                                              "fontWeight": "normal"
                                            }

                                    {
                                      "type": "frame",
                                      "id": "SRF110",
                                      "name": "section1",
                                      "width": "fill_container",
                                      "layout": "vertical",
                                      "gap": 10,
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "SRF111",
                                          "name": "heading1",
                                          "fill": "#1A1A1A",
                                          "content": "# 1. Introduction",
                                          "fontFamily": "Inter",
                                          "fontSize": 22,
                                          "fontWeight": "700"
                                        },
                                        {
                                          "type": "text",
                                          "id": "SRF112",
                                          "name": "introPara",
                                          "fill": "#374151",
                                          "content": "In a world that keeps changing, the ability to learn matters as much as what we already know. Lifelong learning supports personal growth, sharper judgment, and stronger careers.",
